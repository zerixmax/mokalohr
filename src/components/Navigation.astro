---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import LanguagePicker from './LanguagePicker.astro';
import { Image } from 'astro:assets';
import logo from '../assets/mrgudic-bura-logo-web.webp';
import { getWina } from '../utils/wineApi';
import type { Wine } from '../types/wine';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const vinaResponse = await getWina(lang);
// Filtriraj vina za prikaz (Amare Gold - Hidden za sada)
const hiddenSlugs: string[] = [];
const allWines = vinaResponse.docs.filter(wine => !hiddenSlugs.includes(wine.slug));

const isHR = lang === 'hr';

// Helper for dynamic collection path
const getWinePath = (slug: string) => {
  return `/${lang}/vina/${slug}`;
};
---

<header class="sticky top-0 left-0 w-full z-100 bg-bura-dark-bg/95 backdrop-blur-xl border-b border-bura-gold-500/20 h-20 transition-all duration-300" transition:persist>
  <nav class="container mx-auto px-4 h-full flex items-center justify-between relative">
    
    <!-- Left: Desktop Links / Mobile Hamburger -->
    <div class="flex items-center space-x-8">
      <!-- Hamburger (Mobile/Tablet) -->
      <button id="menu-toggle" class="md:hidden p-2 -ml-2 hover:bg-white/10 rounded-full transition-colors relative z-110" aria-label="Menu">
        <svg id="hamburger-svg" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 transition-all duration-300 text-bura-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="hamburger-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h16M4 16h16" />
        </svg>
      </button>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-6">
        <a href={`/${lang}`} class="text-[11px] font-extrabold uppercase tracking-[0.2em] hover:text-bura-gold-400 transition-colors text-white/80">{t('nav.home')}</a>
        
        <!-- Collection Dropdown -->
        <div class="relative group">
          <button class="flex items-center text-[11px] font-extrabold uppercase tracking-[0.2em] hover:text-bura-gold-400 transition-colors group text-white/80">
            {t('nav.collection')}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 ml-1 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="absolute top-full -left-4 pt-4 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-300">
            <div class="bg-bura-dark-paper/98 backdrop-blur-xl border border-bura-gold-500/20 shadow-2xl rounded-2xl p-4 w-64 space-y-1">
              {allWines.map((wine) => (
                <a href={getWinePath(wine.slug)} class="flex items-center space-x-3 p-3 rounded-xl hover:bg-white/10 transition-colors group/item text-white/80">
                  <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center overflow-hidden shrink-0">
                    {wine.slika && <Image src={wine.slika.url} alt={wine.naziv} width={wine.slika.width ?? 400} height={wine.slika.height ?? 800} class="h-6 w-auto object-contain" />}
                  </div>
                  <div>
                    <p class="text-sm font-bold font-playfair group-hover/item:text-bura-gold-400 transition-colors">{wine.naziv}</p>
                    <p class="text-[9px] text-white/40 uppercase tracking-tighter">{wine.category_title}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href={`/${lang}#winery`} class="text-[11px] font-extrabold uppercase tracking-[0.2em] hover:text-bura-gold-400 transition-colors text-white/80">{t('nav.winery')}</a>
        <a href={`/${lang}#about`} class="text-[11px] font-extrabold uppercase tracking-[0.2em] hover:text-bura-gold-400 transition-colors text-white/80">{t('nav.about')}</a>
        <a href={`/${lang}#contact`} class="text-[11px] font-extrabold uppercase tracking-[0.2em] hover:text-bura-gold-400 transition-colors text-white/80">{t('nav.contact')}</a>
      </div>
    </div>

    <!-- Center: Brand Name (placeholder until logo) -->
    <a href={`/${lang}`} class="absolute left-1/2 -translate-x-1/2 flex items-center group z-105">
      <span class="font-playfair text-lg font-bold text-bura-gold-500 tracking-wider">MRGUDIĆ BURA</span>
    </a>

    <!-- Right: Language (Desktop) -->
    <div class="hidden md:flex items-center">
      <LanguagePicker />
    </div>
  </nav>

  <!-- Mobile Menu - Simple Dropdown -->
  <div id="mobile-menu" class="md:hidden absolute top-full left-0 right-0 z-50 bg-bura-dark-bg/98 backdrop-blur-xl border-b border-white/10 shadow-2xl invisible opacity-0 transition-all duration-300 transform -translate-y-2 pointer-events-none max-h-[70vh] overflow-y-auto">
    <div class="px-4 py-4">
      <!-- Main Links -->
      <div class="space-y-1 mb-4">
        <a href={`/${lang}`} class="block py-3 px-4 text-base font-medium text-white hover:bg-white/10 rounded-lg transition-colors">{t('nav.home')}</a>
        <a href={`/${lang}#winery`} class="block py-3 px-4 text-base font-medium text-white hover:bg-white/10 rounded-lg transition-colors">{t('nav.winery')}</a>
        <a href={`/${lang}#about`} class="block py-3 px-4 text-base font-medium text-white hover:bg-white/10 rounded-lg transition-colors">{t('nav.about')}</a>
        <a href={`/${lang}#contact`} class="block py-3 px-4 text-base font-medium text-white hover:bg-white/10 rounded-lg transition-colors">{t('nav.contact')}</a>
      </div>
      
      <!-- Wines Grid - Simple -->
      <div class="border-t border-white/10 pt-4">
        <p class="text-xs uppercase tracking-wider text-white/50 px-4 mb-2">{t('nav.collection')}</p>
        <div class="grid grid-cols-2 gap-1">
          {allWines.map((wine) => (
            <a href={getWinePath(wine.slug)} class="flex items-center py-2 px-3 rounded-lg hover:bg-white/10 transition-colors">
              <span class="text-sm font-medium text-white truncate">{wine.naziv}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Header Divider -->
<div class="h-px bg-linear-to-r from-transparent via-bura-gold-500/50 to-transparent"></div>

<script is:inline>
  function setupNav() {
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const svg = document.getElementById('hamburger-svg');
    const path = document.getElementById('hamburger-path');
    
    if (!menuToggle || !mobileMenu) return;
    
    let isMenuOpen = false;

    const closeMenu = () => {
      if (!mobileMenu) return;
      mobileMenu.classList.add('invisible', 'opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('visible', 'opacity-100');
      mobileMenu.classList.add('-translate-y-2');
      mobileMenu.classList.remove('translate-y-0');
      isMenuOpen = false;
      if (svg) svg.style.transform = 'rotate(0deg)';
      if (path) path.setAttribute('d', 'M4 8h16M4 16h16');
    };

    const openMenu = () => {
      if (!mobileMenu) return;
      mobileMenu.classList.remove('invisible', 'opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('visible', 'opacity-100');
      mobileMenu.classList.remove('-translate-y-2');
      mobileMenu.classList.add('translate-y-0');
      isMenuOpen = true;
      if (svg) svg.style.transform = 'rotate(90deg)';
      if (path) path.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    };

    menuToggle.addEventListener('click', () => {
      if (isMenuOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (isMenuOpen && !menuToggle.contains(e.target) && !mobileMenu.contains(e.target)) {
        closeMenu();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) {
        closeMenu();
      }
    });
  }

  document.addEventListener('DOMContentLoaded', setupNav);
  document.addEventListener('astro:page-load', setupNav);
</script>