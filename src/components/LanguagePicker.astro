---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

function toggleLanguagePath(pathname: string, currentLang: string) {
  const newLang = currentLang === 'hr' ? 'en' : 'hr';
  let parts = pathname.split('/').filter(Boolean);

  if (parts[0] === currentLang) {
    parts[0] = newLang;
  } else {
    parts.unshift(newLang);
  }

  // FORCE /vina/ for both languages to avoid 404s
  if (parts[1] === 'wine' || parts[1] === 'vina') {
    parts[1] = 'vina';
  }

  return '/' + parts.join('/');
}

const currentPath = new URL(Astro.request.url).pathname;
const newPath = toggleLanguagePath(currentPath, lang);

const isHR = lang === 'hr';
---

<a href={newPath} class="inline-flex items-center px-3 py-1 border border-black/10 dark:border-white/10 rounded-full hover:bg-black/5 dark:hover:bg-white/5 transition-all group" aria-label={isHR ? "Switch to English" : "Prebaci na Hrvatski"}>
  <span class={`text-[10px] font-bold uppercase tracking-widest ${isHR ? 'text-bura-muted dark:text-white/40' : 'text-bura-wine-red'}`}>HRV</span>
  <span class="mx-2 w-px h-3 bg-black/10 dark:bg-white/10"></span>
  <span class={`text-[10px] font-bold uppercase tracking-widest ${!isHR ? 'text-bura-muted dark:text-white/40' : 'text-bura-wine-red'}`}>ENG</span>
</a>