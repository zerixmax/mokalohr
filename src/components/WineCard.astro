---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import placeholderBottle from '../assets/boca-vina-mrgudic-placeholder.webp';
import whiteWinePlaceholder from '../assets/mrgudic-bura-bijelovino-placeholder.webp';

type WineEntry = CollectionEntry<'vina'>;

interface Props {
  wine: WineEntry;
  batch?: string;
}

const { wine, batch } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isHR = lang === 'hr';

const nutrition = wine.data.nutricija;
const analysis = wine.data.analiza;
const alcohol = analysis?.alkohol ?? wine.data.alcohol;
---

<div class="max-w-4xl mx-auto bg-bura-dark-800 border border-bura-brown rounded-lg overflow-hidden shadow-2xl flex flex-col md:flex-row my-8">
  <div class="md:w-1/2 min-h-[400px] relative">
      <Image
        src={wine.data.image || (wine.data.visual_theme?.theme_type === 'Marica-Red' ? placeholderBottle : whiteWinePlaceholder)}
        alt={wine.data.name}
        class="absolute inset-0 w-full h-full object-cover"
      />
  </div>

  <div class="px-8 py-10 flex-1 flex flex-col justify-center">
    <div class="mb-4">
      <p class="text-bura-gold-300 text-xs uppercase tracking-widest">{wine.data.category_title}</p>
      <h2 class="font-playfair text-4xl text-bura-gold-500 mb-2">{wine.data.name}</h2>
      <p class="text-bura-light/70 text-lg">{wine.data.year}</p>
    </div>

    <div class="space-y-3 border-t border-bura-brown pt-4 mb-6">
      <div class="flex justify-between text-sm">
        <span class="text-bura-gold-300 uppercase">{t('wine.producer')}</span>
        <span class="text-bura-light">{wine.data.producer}</span>
      </div>
      {wine.data.sort && (
        <div class="flex justify-between text-sm">
          <span class="text-bura-gold-300 uppercase">{t('wine.grape')}</span>
          <span class="text-bura-light">{wine.data.sort}</span>
        </div>
      )}
      {alcohol !== undefined && (
        <div class="flex justify-between text-sm">
          <span class="text-bura-gold-300 uppercase">{t('wine.alcohol')}</span>
          <span class="text-bura-light">{alcohol}% vol</span>
        </div>
      )}
    </div>

    {batch && (
      <div class="mb-6 p-3 bg-bura-dark-900 rounded border border-bura-gold-500/30">
        <p class="text-bura-gold-500 text-sm font-semibold uppercase">
          {isHR ? 'Serija / Batch' : 'Batch'}
        </p>
        <p class="text-bura-light text-2xl font-mono">{batch}</p>
      </div>
    )}

    <!-- EU Nutrition Table -->
    {nutrition && (
      <div class="mb-6">
        <h3 class="text-bura-gold-300 text-xs uppercase tracking-wider mb-3">
          {t('wine.nutrition')} ({isHR ? 'na 100ml' : 'per 100ml'})
        </h3>
        <div class="bg-bura-dark-900 rounded p-4 text-sm">
          <table class="w-full">
            <tbody>
              <tr class="border-b border-bura-brown/50">
                <td class="py-2 text-bura-light/70">{t('wine.energy')}</td>
                <td class="py-2 text-bura-light text-right font-mono">{nutrition.energija} kJ/kcal</td>
              </tr>
              {nutrition.ugljikohidrati !== undefined && (
                <tr class="border-b border-bura-brown/50">
                  <td class="py-2 text-bura-light/70">{t('wine.carbs')}</td>
                  <td class="py-2 text-bura-light text-right font-mono">{nutrition.ugljikohidrati}g</td>
                </tr>
              )}
              {nutrition.seceri !== undefined && (
                <tr class="border-b border-bura-brown/50">
                  <td class="py-2 text-bura-light/70">{t('wine.sugars')}</td>
                  <td class="py-2 text-bura-light text-right font-mono">{nutrition.seceri}g</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    )}

    <!-- Lab Analysis -->
    {analysis && (analysis.suhi_ekstrakt || analysis.ukupna_kiselost || analysis.ukupni_so2) && (
      <div class="mb-6">
        <h3 class="text-bura-gold-300 text-xs uppercase tracking-wider mb-3">
          {t('wine.analysis')}
        </h3>
        <div class="bg-bura-dark-900 rounded p-4 text-sm">
          <table class="w-full">
            <tbody>
              {analysis.suhi_ekstrakt !== undefined && (
                <tr class="border-b border-bura-brown/50">
                  <td class="py-2 text-bura-light/70">{t('wine.extract')}</td>
                  <td class="py-2 text-bura-light text-right font-mono">{analysis.suhi_ekstrakt} g/L</td>
                </tr>
              )}
              {analysis.ukupna_kiselost !== undefined && (
                <tr class="border-b border-bura-brown/50">
                  <td class="py-2 text-bura-light/70">{t('wine.acidity')}</td>
                  <td class="py-2 text-bura-light text-right font-mono">{analysis.ukupna_kiselost} g/L</td>
                </tr>
              )}
              {analysis.ukupni_so2 !== undefined && (
                <tr>
                  <td class="py-2 text-bura-light/70">{t('wine.so2')}</td>
                  <td class="py-2 text-bura-light text-right font-mono">{analysis.ukupni_so2} mg/L</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    )}

    <!-- Allergens - EU Required -->
    {wine.data.allergens && (
      <div class="mb-6 p-3 bg-bura-dark-900 rounded border-l-4 border-red-500">
        <p class="text-red-400 text-xs uppercase mb-1">
          ⚠️ {t('wine.allergens')}
        </p>
        <p class="text-bura-light font-semibold">{wine.data.allergens}</p>
      </div>
    )}

    <!-- Ingredients -->
    {wine.data.ingredients && (
      <div class="mb-6">
        <p class="text-bura-gold-300 text-xs uppercase mb-1">
          {t('wine.ingredients')}
        </p>
        <p class="text-bura-light/80 text-sm">{wine.data.ingredients}</p>
      </div>
    )}

    {wine.data.recycling && (
      <div class="text-xs text-bura-light/50 italic mb-6">
        ♻️ {wine.data.recycling}
      </div>
    )}

    {wine.data.aromas && wine.data.aromas.length > 0 && (
      <div class="mb-6">
         <span class="text-bura-gold-300 text-xs uppercase tracking-wider block mb-2">
           {isHR ? 'Arome' : 'Aromas'}
         </span>
         <div class="flex flex-wrap gap-2">
            {wine.data.aromas.map((aroma: { aroma: string } | string) => {
              const label = typeof aroma === 'string' ? aroma : aroma.aroma;
              return <span class="px-3 py-1 bg-bura-dark-900 rounded-full text-xs border border-white/10 text-bura-gold-400">{label}</span>;
            })}
         </div>
      </div>
    )}

    {wine.data.character && (
      <div class="mb-6">
        <span class="text-bura-gold-300 text-xs uppercase tracking-wider block mb-2">
          {isHR ? 'Karakter' : 'Character'}
        </span>
        <p class="text-bura-light/80 text-sm italic">"{wine.data.character}"</p>
      </div>
    )}

    {wine.data.pairings && wine.data.pairings.length > 0 && (
      <div class="mb-6">
        <span class="text-bura-gold-300 text-xs uppercase tracking-wider block mb-2">
          {t('wine.pairing')}
        </span>
        <div class="space-y-2">
          {wine.data.pairings.map((p: { icon: string; desc: string }) => (
            <p class="text-bura-light/80 text-sm">• {p.desc}</p>
          ))}
        </div>
      </div>
    )}

    <div class="mt-auto pt-4 border-t border-bura-brown">
      <a href={`/${lang}`} class="inline-flex items-center text-bura-gold-500 hover:text-bura-gold-300 transition-colors text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {isHR ? 'Povratak na popis' : 'Back to list'}
      </a>
    </div>
  </div>
</div>
