---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { wine } = Astro.props;
---

<div class="max-w-4xl mx-auto bg-dark border border-gold/30 rounded-lg overflow-hidden shadow-2xl flex flex-col md:flex-row my-8 transform transition hover:-translate-y-1 hover:shadow-gold/10 duration-300">
  <div class="md:w-1/2 min-h-[400px] relative">
      <Image 
        src={wine.data.image} 
        alt={wine.data.name}
        class="absolute inset-0 w-full h-full object-cover"
      />
  </div>
  
  <div class="px-8 py-10 md:w-1/2 flex flex-col justify-center">
    <h2 class="font-playfair text-4xl text-gold mb-2">{wine.data.name}</h2>
    <p class="text-text-muted text-sm tracking-widest uppercase mb-6">{wine.data.tagline}</p>
    
    <p class="text-text-light/90 leading-relaxed mb-8">{wine.data.description}</p>
    
    <div class="space-y-4 border-t border-gold/20 pt-6">
      <div class="flex justify-between items-center">
        <span class="text-gold/80 text-sm font-semibold uppercase tracking-wider">{t('wine.grape')}</span>
        <span class="text-text-light">{wine.data.grape}</span>
      </div>
      
      {wine.data.alcohol && (
        <div class="flex justify-between items-center">
          <span class="text-gold/80 text-sm font-semibold uppercase tracking-wider">{t('wine.alcohol')}</span>
          <span class="text-text-light">{wine.data.alcohol}</span>
        </div>
      )}
    </div>

    {wine.data.tastingNotes && wine.data.tastingNotes.length > 0 && (
      <div class="mt-6">
         <span class="text-gold/80 text-sm font-semibold uppercase tracking-wider block mb-2">{t('wine.tastingNotes')}</span>
         <ul class="list-disc list-inside text-text-light/80 text-sm space-y-1">
            {wine.data.tastingNotes.map((note: string) => (
              <li>{note}</li>
            ))}
         </ul>
      </div>
    )}

    {wine.data.pairing && (
      <div class="mt-6">
        <span class="text-gold/80 text-sm font-semibold uppercase tracking-wider block mb-2">{t('wine.pairing')}</span>
        <p class="text-text-light/80 text-sm">{wine.data.pairing}</p>
      </div>
    )}

    <div class="mt-8 pt-4">
      <a href={`/${lang}`} class="inline-flex items-center text-gold hover:text-gold-hover transition-colors text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {lang === 'hr' ? 'Povratak na popis' : 'Back to list'}
      </a>
    </div>
  </div>
</div>
