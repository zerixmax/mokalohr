---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<footer class="py-10 border-t border-gold/20 mt-20 text-center">
  <div class="container mx-auto px-4">
    <h3 class="font-playfair text-2xl text-gold mb-4">{t('contact.title')}</h3>
    <a href={`mailto:${t('contact.email')}`} class="text-text-muted hover:text-gold transition-colors">{t('contact.email')}</a>
    <p class="text-xs text-text-muted mt-8 opacity-50">&copy; {new Date().getFullYear()} Mrgudić Bura Vina. Sva prava pridržana.</p>
  </div>
</footer>
