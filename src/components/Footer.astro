---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import versions from '../data/versions.json';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentVersion = versions.currentVersion;
---

<footer class="py-16 border-t border-bura-gold-500/20 bg-bura-dark-bg">
  <div class="container mx-auto px-4 text-center">
    <div class="mb-8">
      <span class="font-playfair text-2xl font-bold text-bura-gold-500 tracking-wider">MRGUDIĆ BURA</span>
    </div>
    
    <div class="space-y-6">
      <h3 class="font-playfair text-xl text-white tracking-wider uppercase opacity-80">{t('contact.title')}</h3>
      
      <div class="flex flex-col items-center space-y-2">
        <p class="font-playfair text-lg font-bold text-white">{t('contact.winery')}</p>
        <p class="text-sm text-white/50 italic">{t('contact.address')}</p>
        <a 
          href={`mailto:${t('contact.email')}`} 
          class="text-white/60 hover:text-bura-gold-400 transition-colors text-sm font-mono border-b border-white/20"
        >
          {t('contact.email')}
        </a>
      </div>

      <div class="flex justify-center space-x-6 pt-4">
        <!-- Facebook -->
        <a 
          href="https://www.facebook.com/vinarija.buramrgudic" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/60 hover:text-[#1877F2] hover:border-[#1877F2]/50 hover:bg-[#1877F2]/10 transition-all duration-300"
          aria-label="Facebook"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        
        <!-- Instagram -->
        <a 
          href="https://www.instagram.com/buramrgudic" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/60 hover:text-[#E4405F] hover:border-[#E4405F]/50 hover:bg-[#E4405F]/10 transition-all duration-300"
          aria-label="Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10">
      <p class="text-[10px] text-white/40 uppercase tracking-[0.2em]">&copy; {new Date().getFullYear()} Mokalo d.o.o. Sva prava pridržana.</p>
    </div>
  </div>
</footer>
