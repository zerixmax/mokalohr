---
// src/components/wine/WineNutrition.astro
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: any;
  data: {
    ingredients: string;
    allergens: string;
    producer: string;
    recycling?: string;
    nutricija?: {
      energija: string;
      ugljikohidrati: number;
      seceri: number;
    };
    analiza?: {
      suhi_ekstrakt?: number;
      reducirajuci_seceri?: number;
      ukupna_kiselost?: number;
      ukupni_so2?: number;
    };
  };
  themeColor: string;
}

const { lang, data, themeColor } = Astro.props;
const t = useTranslations(lang);
const isHR = lang === 'hr';
const ingredientsList = data.ingredients ? data.ingredients.split(',').map(i => i.trim()) : [];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <!-- Ingredients Section -->
  <section class="bg-bura-dark-bg/60 backdrop-blur-sm p-6 rounded-2xl border border-white/10 shadow-sm">
    <h3 class="font-playfair text-xl mb-4 uppercase tracking-widest text-bura-gold-400">
      {t('wine.ingredients')}
    </h3>
    <div class="flex flex-wrap gap-2">
      {ingredientsList.map((item) => (
        <span class="px-3 py-1.5 bg-bura-dark-paper rounded-full text-xs border border-white/10 text-white/80">{item}</span>
      ))}
    </div>
  </section>

  <!-- Allergens Section -->
  <section class="bg-bura-dark-bg/60 backdrop-blur-sm p-6 rounded-2xl border border-white/10 shadow-sm">
    <h3 class="font-playfair text-xl mb-4 uppercase tracking-widest text-bura-gold-400">
      {t('wine.allergens')}
    </h3>
    <div class="flex items-center gap-3">
      <span class="text-bura-gold-500 text-xl">⚠️</span>
      <p class="text-white font-semibold">{data.allergens}</p>
    </div>
  </section>

  <!-- Nutrition Section -->
  {data.nutricija && (
    <section class="bg-bura-dark-bg/60 backdrop-blur-sm p-6 rounded-2xl border border-white/10 shadow-sm">
      <h3 class="font-playfair text-xl mb-4 uppercase tracking-widest text-bura-gold-400">
        {t('wine.nutrition')}
      </h3>
      <div class="space-y-2 text-[11px]">
        <div class="flex justify-between p-2 bg-bura-dark-paper rounded-lg">
          <span class="text-white/50">{t('wine.energy')}</span>
          <span class="font-bold text-white">{data.nutricija.energija}</span>
        </div>
        <div class="flex justify-between p-2 bg-bura-dark-paper rounded-lg">
          <span class="text-white/50">{t('wine.carbs')}</span>
          <span class="font-bold text-white">{data.nutricija.ugljikohidrati ?? '0'}g</span>
        </div>
        <div class="flex justify-between p-2 bg-bura-dark-paper rounded-lg">
          <span class="text-white/50">{t('wine.sugars')}</span>
          <span class="font-bold text-white">{data.nutricija.seceri ?? '0'}g</span>
        </div>
      </div>
    </section>
  )}

  <!-- Laboratory Analysis Section -->
  {data.analiza && (
    <section class="bg-bura-dark-bg/60 backdrop-blur-sm p-6 rounded-2xl border border-white/10 shadow-sm">
      <h3 class="font-playfair text-xl mb-4 uppercase tracking-widest text-bura-gold-400">
        {t('wine.analysis')}
      </h3>
      <div class="space-y-2 text-[11px]">
        {[
          { label: t('wine.extract'), val: data.analiza.suhi_ekstrakt, unit: ' g/l' },
          { label: t('wine.reducing_sugars'), val: data.analiza.reducirajuci_seceri, unit: ' g/l' },
          { label: t('wine.acidity'), val: data.analiza.ukupna_kiselost, unit: ' g/l' },
          { label: t('wine.so2'), val: data.analiza.ukupni_so2, unit: ' mg/L' }
        ].map((item) => (
          <div class="flex justify-between p-2 bg-bura-dark-paper rounded-lg">
            <span class="text-white/50">{item.label}</span>
            <span class="font-bold text-white">{item.val ?? '-'}{item.unit}</span>
          </div>
        ))}
      </div>
    </section>
  )}
</div>

<!-- Producer Section - Full Width -->
<section class="bg-bura-dark-bg/60 backdrop-blur-sm p-6 rounded-2xl border border-white/10 shadow-sm mt-8">
  <h3 class="font-playfair text-xl mb-4 uppercase tracking-widest text-bura-gold-400">
    {isHR ? 'Proizvođač' : 'Producer'}
  </h3>
  <p class="text-sm font-bold text-white/80 italic">
    OPG Mrgudić-Bura<br/>
    Potomje 7, 20244 Potomje, Pelješac<br/>
    Hrvatska / Croatia
  </p>
  {data.recycling && (
    <div class="mt-4 pt-4 border-t border-white/10 text-[11px] text-white/50 italic flex items-center gap-2">
      <span class="text-lg">♻️</span> {data.recycling}
    </div>
  )}
</section>
