---
// src/components/wine/RichText.astro
// Payload CMS Lexical RichText → HTML Renderer
// Supports: text, paragraph, heading, list, listitem, quote, link, linebreak, hr, indent

interface Props {
  content: any;
  className?: string;
}

const { content, className = '' } = Astro.props;

if (!content || !content.root || !content.root.children || content.root.children.length === 0) {
  return null;
}

// Text format bitmasks (Lexical)
const FORMAT = {
  BOLD: 1 << 0,       // 1
  ITALIC: 1 << 1,     // 2
  STRIKETHROUGH: 1 << 2,  // 4
  UNDERLINE: 1 << 3,  // 8
  CODE: 1 << 4,       // 16
  SUBSCRIPT: 1 << 5,  // 32
  SUPERSCRIPT: 1 << 6, // 64
  HIGHLIGHT: 1 << 7,  // 128
};

function applyTextFormat(text: string, format: number): string {
  let result = text;
  if (format & FORMAT.BOLD) result = `<strong>${result}</strong>`;
  if (format & FORMAT.ITALIC) result = `<em>${result}</em>`;
  if (format & FORMAT.UNDERLINE) result = `<u>${result}</u>`;
  if (format & FORMAT.STRIKETHROUGH) result = `<s>${result}</s>`;
  if (format & FORMAT.CODE) result = `<code>${result}</code>`;
  if (format & FORMAT.SUBSCRIPT) result = `<sub>${result}</sub>`;
  if (format & FORMAT.SUPERSCRIPT) result = `<sup>${result}</sup>`;
  if (format & FORMAT.HIGHLIGHT) result = `<mark>${result}</mark>`;
  return result;
}

function renderNode(node: any): string {
  if (node.type === 'text') {
    return applyTextFormat(node.text || '', node.format || 0);
  }

  if (node.type === 'linebreak') {
    return '<br/>';
  }

  if (node.type === 'paragraph') {
    const inner = node.children.map(renderNode).join('');
    return `<p class="mb-4 last:mb-0">${inner}</p>`;
  }

  if (node.type === 'heading') {
    const Tag = node.tag || 'h2';
    const headingClass = `font-playfair mb-4 mt-6 text-bura-gold-400 ${
      Tag === 'h1' ? 'text-3xl font-bold' :
      Tag === 'h2' ? 'text-2xl' :
      Tag === 'h3' ? 'text-xl' :
      'text-lg'
    }`;
    const inner = node.children.map(renderNode).join('');
    return `<${Tag} class="${headingClass}">${inner}</${Tag}>`;
  }

  if (node.type === 'list') {
    const Tag = node.listType === 'number' ? 'ol' : 'ul';
    const listClass = node.listType === 'number' ? 'list-decimal' : 'list-disc';
    const inner = node.children.map(renderNode).join('');
    return `<${Tag} class="${listClass} ml-6 mb-4 space-y-1">${inner}</${Tag}>`;
  }

  if (node.type === 'listitem') {
    const inner = node.children.map(renderNode).join('');
    return `<li class="mb-1">${inner}</li>`;
  }

  if (node.type === 'check') {
    const inner = node.children.map(renderNode).join('');
    const checked = node.checked ? 'checked' : '';
    return `<div class="flex items-center gap-2 mb-2"><input type="checkbox" disabled ${checked} class="accent-bura-gold-400"/><span>${inner}</span></div>`;
  }

  if (node.type === 'quote') {
    const inner = node.children.map(renderNode).join('');
    return `<blockquote class="border-l-4 border-bura-gold-400/50 pl-4 italic text-white/60 mb-4">${inner}</blockquote>`;
  }

  if (node.type === 'link') {
    const inner = node.children.map(renderNode).join('');
    const url = node.fields?.url || '#';
    const newTab = node.fields?.newTab ? ' target="_blank" rel="noopener noreferrer"' : '';
    return `<a href="${url}" class="text-bura-gold-400 underline hover:text-bura-gold-300 transition-colors"${newTab}>${inner}</a>`;
  }

  if (node.type === 'horizontalrule') {
    return '<hr class="border-white/10 my-6"/>';
  }

  if (node.type === 'code') {
    const code = node.code || '';
    return `<pre class="bg-bura-dark-bg/50 rounded-lg p-4 mb-4 overflow-x-auto border border-white/10"><code>${code}</code></pre>`;
  }

  if (node.type === 'upload') {
    const imgUrl = node.value?.url || '';
    const alt = node.value?.alt || '';
    const caption = node.caption ? node.children.map(renderNode).join('') : '';
    return `<figure class="mb-6"><img src="${imgUrl}" alt="${alt}" class="rounded-lg w-full max-w-md mx-auto"/><figcaption class="text-center text-xs text-white/50 mt-2 italic">${caption}</figcaption></figure>`;
  }

  if (node.type === 'indent') {
    const inner = node.children.map(renderNode).join('');
    const indentLevel = node.direction === 'ltr' ? 'ml-6' : 'mr-6';
    return `<div class="${indentLevel}">${inner}</div>`;
  }

  // Fallback: render children if they exist
  if (node.children) {
    return node.children.map(renderNode).join('');
  }

  return '';
}

const html = content.root.children.map(renderNode).join('');
---

<div class="rich-text text-white/80 leading-relaxed text-sm {className}">
  <div set:html={html} />
</div>

<style is:global>
  .rich-text p {
    margin-bottom: 1rem;
  }
  .rich-text strong {
    color: white;
    font-weight: 700;
  }
  .rich-text em {
    font-style: italic;
  }
  .rich-text a {
    color: #b5935a;
    text-decoration: underline;
    transition: color 0.2s;
  }
  .rich-text a:hover {
    color: #d4b87a;
  }
  .rich-text ul, .rich-text ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .rich-text li {
    margin-bottom: 0.25rem;
  }
  .rich-text h1, .rich-text h2, .rich-text h3, .rich-text h4 {
    font-family: 'Playfair Display', serif;
    color: #b5935a;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  .rich-text h1 { font-size: 1.875rem; font-weight: bold; }
  .rich-text h2 { font-size: 1.5rem; }
  .rich-text h3 { font-size: 1.25rem; }
  .rich-text h4 { font-size: 1.125rem; }
  .rich-text blockquote {
    border-left: 4px solid rgba(181, 147, 90, 0.5);
    padding-left: 1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1rem;
  }
  .rich-text hr {
    border-color: rgba(255, 255, 255, 0.1);
    margin: 1.5rem 0;
  }
  .rich-text pre {
    background: rgba(36, 32, 33, 0.5);
    border-radius: 0.5rem;
    padding: 1rem;
    margin-bottom: 1rem;
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .rich-text code {
    font-family: monospace;
    font-size: 0.875rem;
  }
  .rich-text figure {
    margin-bottom: 1.5rem;
  }
  .rich-text figure img {
    border-radius: 0.5rem;
    max-width: 100%;
  }
  .rich-text figcaption {
    text-align: center;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.5rem;
    font-style: italic;
  }
  .rich-text mark {
    background: rgba(181, 147, 90, 0.3);
    color: white;
    padding: 0 0.25rem;
  }
  .rich-text u {
    text-decoration: underline;
  }
  .rich-text s {
    text-decoration: line-through;
  }
  .rich-text sub {
    vertical-align: sub;
    font-size: smaller;
  }
  .rich-text sup {
    vertical-align: super;
    font-size: smaller;
  }
</style>
