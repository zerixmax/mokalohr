---
// src/components/wine/MultiWineSelector.astro
import { Image } from 'astro:assets';

interface Props {
  allMatches: any[];
  lang: string;
  baseSlug: string;
  themeMap: Record<string, string>;
}

const { allMatches, lang, baseSlug, themeMap } = Astro.props;
const isHR = lang === 'hr';
---

<section class="relative min-h-[80vh] flex flex-col items-center justify-center p-8">
  <div class="max-w-4xl w-full text-center space-y-16 py-12">
    <div class="space-y-4">
      <span class="text-bura-muted dark:text-white/40 uppercase tracking-[0.5em] text-[10px] font-bold block animate-fade-in">
        {isHR ? 'Dostupna vina u seriji' : 'Available wines in series'}
      </span>
      <h1 class="font-playfair text-5xl md:text-8xl font-bold tracking-tighter text-bura-ink dark:text-bura-dark-ink">
        {baseSlug}
      </h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {allMatches.map((v: any) => {
        const vThemeColor = themeMap[(v.visual_theme?.theme_type as keyof typeof themeMap) || 'Marica-Red'];
        return (
          <a 
            href={`/${lang}/vina/${baseSlug}?id=${v.id}`} 
            class="group relative bg-white/40 dark:bg-bura-dark-paper/40 backdrop-blur-md p-8 rounded-[2.5rem] border border-black/5 dark:border-white/5 hover:border-black/20 dark:hover:border-white/20 transition-all hover:scale-[1.03] shadow-sm hover:shadow-2xl overflow-hidden text-left"
          >
            <div class="absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity" style={`background: radial-gradient(circle at top right, ${vThemeColor}, transparent);`}></div>
            
            <div class="relative z-10 space-y-10">
              <div class="flex justify-between items-start">
                <span class="text-xs font-bold text-bura-muted dark:text-white/40 uppercase tracking-[0.2em]">{v.year}. BERBA</span>
                <span class="w-10 h-10 rounded-full flex items-center justify-center border border-black/10 dark:border-white/10 group-hover:bg-black dark:group-hover:bg-white dark:group-hover:text-black group-hover:text-white transition-all transform group-hover:rotate-45">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </span>
              </div>
              
              <div>
                <h2 class="font-playfair text-4xl font-bold group-hover:translate-x-1 transition-transform leading-tight" style={`color: ${vThemeColor};`}>{v.naziv}</h2>
              </div>

              <div class="flex items-center gap-8 pt-6 border-t border-black/5 dark:border-white/5">
                <div class="flex flex-col">
                  <span class="text-[9px] uppercase tracking-widest opacity-40 font-black mb-1">LOT</span>
                  <span class="font-mono font-bold text-xl tracking-tighter dark:text-bura-dark-ink">{v.boris_lot || v.lot}</span>
                </div>
                {v.datum_punjenja && (
                  <div class="flex flex-col border-l border-black/10 dark:border-white/10 pl-8">
                    <span class="text-[9px] uppercase tracking-widest opacity-40 font-black mb-1">{isHR ? 'Punjenje' : 'Filling'}</span>
                    <span class="font-bold text-xl tracking-tighter dark:text-bura-dark-ink">{new Date(v.datum_punjenja).toLocaleDateString(isHR ? 'hr-HR' : 'en-US')}</span>
                  </div>
                )}
              </div>
            </div>
          </a>
        )
      })}
    </div>
    
    <div class="pt-8">
      <a href={`/${lang}`} class="group inline-flex items-center gap-3 text-xs font-bold uppercase tracking-[0.4em] text-bura-muted hover:text-bura-ink transition-all">
        <span class="group-hover:-translate-x-1 transition-transform">←</span>
        <span class="border-b border-black/10 pb-1">{isHR ? 'POVRATAK NA SVE' : 'BACK TO ALL'}</span>
      </a>
    </div>
  </div>
</section>
