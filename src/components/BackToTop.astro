<button 
  id="back-to-top" 
  class="fixed bottom-24 right-8 z-[90] w-14 h-14 bg-bura-dark-paper/90 backdrop-blur-xl border-2 border-bura-gold-500/40 rounded-full shadow-2xl shadow-black/50 flex items-center justify-center text-bura-gold-500 transition-all duration-500 hover:scale-110 hover:border-bura-gold-400 active:scale-95 group cursor-pointer invisible opacity-0"
  aria-label="Back to top"
>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    class="w-6 h-6" 
    fill="none" 
    viewBox="0 0 24 24" 
    stroke="currentColor"
  >
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
  </svg>
</button>

<style>
  @keyframes float-up {
    0%, 100% {
      transform: translateY(4px);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 0 20px rgba(184, 134, 11, 0.3);
    }
    50% {
      box-shadow: 0 0 30px rgba(184, 134, 11, 0.6);
    }
  }

  #back-to-top.visible {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    animation: float-up 2s ease-in-out infinite, pulse-glow 3s ease-in-out infinite;
  }
</style>

<script>
  const backToTop = document.getElementById('back-to-top');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 400) {
      backToTop?.classList.add('visible');
    } else {
      backToTop?.classList.remove('visible');
    }
  });

  backToTop?.addEventListener('click', () => {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  });
</script>