---
import Layout from '../../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';

// Import logos for the bottom
import logo1 from '../../../assets/mrgudic-bura-logo-web.webp';
import logo2 from '../../../assets/mrgudic-bura-logo-web.webp'; 
import logo3 from '../../../assets/mrgudic-bura-logo-web.webp';
import placeholderBottle from '../../../assets/boca-vina-mrgudic-placeholder.webp';
import whiteWinePlaceholder from '../../../assets/mrgudic-bura-bijelovino-placeholder.webp';

const { lang, slug: fullSlug } = Astro.params;
const [baseSlug, batchFromUrl] = fullSlug.split('/');

// Fetch wine data from Payload CMS
const response = await fetch(`https://cms.mokalo.hr/api/vina?where[slug][equals]=${baseSlug}&locale=${lang}&depth=1`);
const result = await response.json();
const vino = result.docs[0];

if (!vino) return Astro.redirect('/404');

// Map Payload data to the structure the template expects
const data = {
  name: vino.naziv,
  category_title: vino.category_title,
  year: vino.year,
  alcohol: vino.alcohol,
  sort: vino.sort,
  aromas: vino.aromas?.map((a: any) => a.aroma) || [],
  character: vino.character,
  technicals: vino.technicals,
  profile: vino.profile,
  serving: vino.serving,
  pairings: vino.pairings,
  visual_theme: vino.visual_theme,
  ingredients: vino.ingredients,
  allergens: vino.allergens,
  nutricija: vino.nutricija,
  analiza: vino.analiza,
  image: vino.slika?.url || null,
  batches: [vino.lot],
};

const t = useTranslations(lang as any);
const batch = batchFromUrl || data.batches?.[0] || null;

const isHR = lang === 'hr';


// === THEME SELECTOR LOGIC ===
const themeMap = {
  'Marica-Red': '#800000',
  'Rukatac-Blue': '#004080',
  'Amare-Gold': '#b8860b'
};

const themeColor = themeMap[(data.visual_theme?.theme_type as keyof typeof themeMap) || 'Marica-Red'];
const heroTitle = data.name.toUpperCase();
const heroSubtitle = data.category_title;

// Analytics / Spider Graph Logic (0-100 scale)
const { profile } = data;
const points = [
  { label: isHR ? 'VOĆNOST' : 'FRUITINESS', val: profile.fruitiness },
  { label: isHR ? 'KISELINA' : 'ACIDITY', val: profile.acidity },
  { label: isHR ? 'FLORALNOST' : 'FLORAL', val: profile.floral },
  { label: isHR ? 'ZAČINI' : 'SPICES', val: profile.spices },
  { label: isHR ? 'TANINI' : 'TANNINS', val: profile.tannins },
];

// SVG Spider Graph Helper
const size = 220;
const center = size / 2;
const radius = size * 0.35;
const getPoint = (i: number, val: number) => {
  const angle = (i / points.length) * Math.PI * 2 - Math.PI / 2;
  const r = (val / 100) * radius;
  return `${center + r * Math.cos(angle)},${center + r * Math.sin(angle)}`;
};
const polygonPath = points.map((p, i) => getPoint(i, p.val)).join(' ');
const bgPath50 = points.map((p, i) => getPoint(i, 50)).join(' ');
const bgPath100 = points.map((p, i) => getPoint(i, 100)).join(' ');
---

<Layout title={data.name} lang={lang} description={`${data.name} - ${data.category_title}`}>
  
  <main class="relative min-h-screen flex flex-col font-inter bg-bura-paper overflow-x-hidden" style={`--theme-color: ${themeColor};`}>
    
    <!-- Hero Section: Bottle & Title Overlay -->
    <section class="relative pt-12 pb-24 px-4 min-h-[70vh] flex flex-col items-center justify-center">
      
      <!-- Large Watermark Title -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden">
        <h1 
          class="text-[25vw] font-bold font-playfair leading-none opacity-[0.03] whitespace-nowrap"
          style={`color: ${themeColor};`}
        >
          {heroTitle}
        </h1>
      </div>

      <!-- Bottle Image Container -->
      <div class="relative z-10 grow w-full flex items-center justify-center py-12">
        <Image 
          src={data.image || (data.visual_theme?.theme_type === 'Marica-Red' ? placeholderBottle : whiteWinePlaceholder)} 
          alt={data.name} 
          class="h-[50vh] w-auto object-contain drop-shadow-[0_40px_80px_rgba(0,0,0,0.3)] transform transition-all duration-1000 hover:scale-105"
          loading="eager"
          transition:name={`bottle-${Astro.params.slug?.split('/')[0]}`}
        />
        <!-- Brand Ribbon -->
        <div class="absolute -bottom-4 md:-bottom-8 left-1/2 -translate-x-1/2 z-20">
          <div class="bura-ribbon whitespace-nowrap">
            {isHR ? 'VINARIJA MRGUDIĆ-BURA' : 'MRGUDIĆ-BURA WINERY'}
          </div>
        </div>
      </div>

      <!-- Label Details Overlay -->
      <div class="relative z-20 text-center space-y-2">
        <span class="text-bura-muted uppercase tracking-[0.5em] text-[10px] font-bold block animate-fade-in">{data.category_title}</span>
        <h2 
          class="font-playfair text-6xl md:text-8xl font-bold tracking-tighter" 
          style={`color: ${themeColor};`}
          transition:name={`title-${Astro.params.slug?.split('/')[0]}`}
        >
          {heroTitle}
        </h2>
        <p class="font-playfair italic text-xl md:text-2xl text-bura-ink/60 uppercase tracking-widest">
          {data.sort}
        </p>
      </div>

      <!-- Scroll Indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-20 animate-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7-7-7" />
        </svg>
      </div>
    </section>

    <!-- Content on Paper -->
    <div class="relative z-30 bg-white/20 backdrop-blur-md border-t border-black/5 rounded-t-[3rem] -mt-12 shadow-[0_-20px_50px_rgba(0,0,0,0.05)]">
      <div class="container mx-auto px-4 py-16 max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
          
          <!-- Column 1: Core Specs -->
          <div class="lg:col-span-4 space-y-6">
            <div class="bg-white/60 p-8 rounded-3xl border border-black/5 shadow-xl space-y-6">
               <div class="flex justify-between items-center border-b border-black/5 pb-4">
                  <span class="text-[10px] text-bura-muted uppercase tracking-widest font-bold">{t('wine.year') || (isHR ? 'Godište' : 'Year')}</span>
                  <span class="font-playfair text-2xl font-bold">{data.year}</span>
               </div>
               <div class="flex justify-between items-center border-b border-black/5 pb-4">
                  <span class="text-[10px] text-bura-muted uppercase tracking-widest font-bold">{isHR ? 'Regija' : 'Region'}</span>
                  <span class="font-playfair text-xl">{data.region}</span>
               </div>
               <div class="flex justify-between items-center pb-2">
                  <span class="text-[10px] text-bura-muted uppercase tracking-widest font-bold">{t('wine.alcohol')}</span>
                  <span class="font-bold text-2xl" style={`color: ${themeColor};`}>{data.alcohol}<span class="text-sm ml-1 opacity-50">%vol</span></span>
               </div>
               {batch && (
                <div class="bg-black/5 p-4 rounded-2xl mt-4 border border-black/5">
                  <span class="text-[9px] text-bura-muted uppercase tracking-widest block mb-1 font-bold">{isHR ? 'Serija / Batch' : 'Series / Batch'}</span>
                  <span class="font-mono text-2xl tracking-tighter font-bold">{batch}</span>
                </div>
               )}

               <!-- Quick Actions -->
               <div class="grid grid-cols-2 gap-3 pt-4">
                  <button 
                    onclick="window.print()" 
                    class="flex flex-col items-center justify-center p-4 bg-white border border-black/5 rounded-2xl hover:bg-bura-wine-red/5 hover:border-bura-wine-red/20 transition-all group"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mb-1 text-bura-muted group-hover:text-bura-wine-red transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-bura-muted group-hover:text-bura-wine-red">{isHR ? 'PDF List' : 'Wine Sheet'}</span>
                  </button>
                  <button 
                    id="share-btn"
                    class="flex flex-col items-center justify-center p-4 bg-white border border-black/5 rounded-2xl hover:bg-bura-wine-red/5 hover:border-bura-wine-red/20 transition-all group"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mb-1 text-bura-muted group-hover:text-bura-wine-red transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                    </svg>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-bura-muted group-hover:text-bura-wine-red">{isHR ? 'Podijeli' : 'Share'}</span>
                  </button>
               </div>
            </div>
          </div>

          <script>
            // Web Share API Integration
            const shareBtn = document.getElementById('share-btn');
            shareBtn?.addEventListener('click', async () => {
              try {
                await navigator.share({
                  title: document.title,
                  text: 'Provjerite digitalnu etiketu Mrgudić Bura Vina',
                  url: window.location.href
                });
              } catch (err) {
                console.log('Share failed or cancelled');
              }
            });
          </script>

        <!-- Right Column: Character, Serving, Pairing -->
        <div class="lg:col-span-8 space-y-8">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Spider Graph -->
            <section class="bg-white/40 backdrop-blur-sm p-6 rounded-2xl border border-black/5 shadow-sm flex flex-col items-center">
              <h2 class="font-playfair text-xl mb-6 uppercase tracking-widest text-center" style={`color: ${themeColor};`}>
                {isHR ? 'Karakter Vina' : 'Wine Character'}
              </h2>
              <div class="relative">
                <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} class="overflow-visible">
                    <polygon points={bgPath100} fill="none" stroke="black" stroke-width="0.5" stroke-dasharray="2,2" opacity="0.1" />
                    <polygon points={bgPath50} fill="none" stroke="black" stroke-width="0.5" stroke-dasharray="2,2" opacity="0.1" />
                    
                    {points.map((_, i) => {
                      const p = getPoint(i, 100);
                      return <line x1={center} y1={center} x2={p.split(',')[0]} y2={p.split(',')[1]} stroke="black" stroke-width="0.5" opacity="0.05" />;
                    })}

                    <polygon points={polygonPath} fill={themeColor} fill-opacity="0.2" stroke={themeColor} stroke-width="2" stroke-linejoin="round" />
                    
                    {points.map((p, i) => {
                      const pos = getPoint(i, 120);
                      const [x, y] = pos.split(',').map(Number);
                      return (
                        <text 
                          x={x} y={y} 
                          text-anchor="middle" 
                          alignment-baseline="middle" 
                          class="text-[9px] font-bold fill-bura-muted uppercase tracking-tighter"
                        >
                          {p.label}
                        </text>
                      );
                    })}
                </svg>
              </div>
            </section>

            <!-- Marketing Content -->
            <div class="space-y-8">
              <section class="bg-white/40 backdrop-blur-sm p-6 rounded-2xl border border-black/5 shadow-sm slats-bg">
                <h2 class="font-playfair text-xl mb-4 uppercase tracking-widest" style={`color: ${themeColor};`}>
                   {isHR ? 'Arome' : 'Aromas'}
                </h2>
                <div class="flex flex-wrap gap-2">
                  {data.aromas.map((aroma: string) => (
                    <span class="px-3 py-1 bg-white/50 rounded-full text-xs border border-black/5" style={`color: ${themeColor};`}>
                      {aroma}
                    </span>
                  ))}
                </div>
                <div class="mt-6 pt-6 border-t border-black/5">
                  <h3 class="text-[10px] font-bold uppercase tracking-widest mb-2 opacity-50">{isHR ? 'Karakter' : 'Character'}</h3>
                  <p class="text-sm italic leading-relaxed text-bura-ink/80">"{data.character}"</p>
                </div>
              </section>

              <!-- Serving Card -->
              <section class="bg-white/40 backdrop-blur-sm p-6 rounded-2xl border border-black/5 shadow-sm overflow-hidden relative">
                <div class="absolute top-0 right-0 w-24 h-24 -mr-8 -mt-8 rounded-full opacity-10" style={`background-color: ${themeColor};`}></div>
                <h2 class="font-playfair text-xl mb-4 uppercase tracking-widest" style={`color: ${themeColor};`}>
                  {isHR ? 'Serviranje' : 'Serving'}
                </h2>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <span class="text-[9px] text-bura-muted uppercase tracking-[0.2em] block mb-1">{isHR ? 'Temperatura' : 'Temperature'}</span>
                    <p class="font-bold text-lg">{data.serving.temp}</p>
                  </div>
                  <div>
                    <span class="text-[9px] text-bura-muted uppercase tracking-[0.2em] block mb-1">{isHR ? 'Preporučena čaša' : 'Glassware'}</span>
                    <p class="text-sm leading-tight">{data.serving.glass}</p>
                  </div>
                </div>
              </section>
            </div>
          </div>

          <!-- Technicals & Pairing -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
             <section class="bg-white/40 backdrop-blur-sm p-6 rounded-2xl border border-black/5 shadow-sm slats-bg">
                <h2 class="font-playfair text-xl mb-4 uppercase tracking-widest" style={`color: ${themeColor};`}>
                   {isHR ? 'Tehnikalije' : 'Technicals'}
                </h2>
                <p class="text-sm leading-relaxed text-bura-ink/70">
                   {data.technicals}
                </p>
             </section>

             <section class="bg-white/60 backdrop-blur-md p-6 rounded-2xl border border-black/5 shadow-lg">
                <h2 class="font-playfair text-xl mb-6 uppercase tracking-widest text-center" style={`color: ${themeColor};`}>
                   {isHR ? 'Sljubljivanje' : 'Pairing'}
                </h2>
                <div class="space-y-4">
                   {data.pairings.map((p: any) => (
                      <div class="flex items-center gap-4 p-3 bg-white/40 rounded-xl border border-black/5">
                         <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style={`background-color: ${themeColor}15; color: ${themeColor};`}>
                            <span class="text-[10px] font-bold uppercase">{p.icon}</span>
                         </div>
                         <p class="text-xs italic text-bura-ink/80 leading-snug">{p.desc}</p>
                      </div>
                   ))}
                </div>
             </section>
          </div>

          <!-- EU Regulation & Laboratory Analysis -->
          <section class="bg-black/3 p-8 rounded-3xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 text-sm">
             <div class="lg:col-span-1 space-y-6">
                <div>
                  <h3 class="font-playfair font-bold uppercase text-[10px] tracking-widest mb-3 opacity-50" style={`color: ${themeColor};`}>{t('wine.ingredients')}</h3>
                  <p class="text-bura-ink/70 leading-relaxed">{data.ingredients}</p>
                </div>
                <div>
                  <h3 class="font-playfair font-bold uppercase text-[10px] tracking-widest mb-3 opacity-50" style={`color: ${themeColor};`}>{t('wine.allergens')}</h3>
                  <p class="inline-block px-4 py-1.5 bg-white rounded-lg shadow-sm font-bold border border-black/5" style={`color: ${themeColor};`}>{data.allergens}</p>
                </div>
                {data.recycling && (
                  <div class="pt-4 flex items-center gap-3 text-[11px] text-bura-muted italic">
                    <span class="text-xl grayscale">♻️</span> {data.recycling}
                  </div>
                )}
             </div>
             
             {data.nutricija && (
               <div class="bg-white/40 p-6 rounded-xl border border-black/5 shadow-sm slats-bg">
                  <h3 class="font-playfair font-bold uppercase text-[10px] tracking-widest mb-6 text-center" style={`color: ${themeColor};`}>{t('wine.nutrition')}</h3>
                  <div class="space-y-1 font-inter text-[11px]">
                    <div class="flex justify-between p-2 bg-black/5 border-b border-black/5 rounded-t-lg">
                      <span class="opacity-60">{t('wine.energy')}</span>
                      <span class="font-bold">{data.nutricija.energija}</span>
                    </div>
                    {[
                      { label: t('wine.carbs'), val: data.nutricija.ugljikohidrati, unit: 'g' },
                      { label: t('wine.sugars'), val: data.nutricija.seceri, unit: 'g' }
                    ].map((item, i) => (
                      <div class={`flex justify-between p-2 ${i % 2 === 0 ? '' : 'bg-black/5'} border-b border-black/5 last:border-0 last:rounded-b-lg`}>
                        <span class="opacity-60">{item.label}</span>
                        <span class="font-bold">{item.val ?? '0'}{item.unit}</span>
                      </div>
                    ))}
                  </div>
               </div>
             )}

             {data.analiza && (
               <div class="bg-white/40 p-6 rounded-xl border border-black/5 shadow-sm slats-bg">
                  <h3 class="font-playfair font-bold uppercase text-[10px] tracking-widest mb-6 text-center" style={`color: ${themeColor};`}>{t('wine.analysis')}</h3>
                  <div class="space-y-1 font-inter text-[11px]">
                    {[
                      { label: t('wine.extract'), val: data.analiza.suhi_ekstrakt, unit: ' g/l' },
                      { label: t('wine.reducing_sugars'), val: data.analiza.reducirajuci_seceri, unit: ' g/l' },
                      { label: t('wine.acidity'), val: data.analiza.ukupna_kiselost, unit: ' g/l' },
                      { label: t('wine.so2'), val: data.analiza.ukupni_so2, unit: ' mg/L' }
                    ].map((item, i) => (
                      <div class={`flex justify-between p-2 ${i % 2 === 0 ? 'bg-black/5' : ''} border-b border-black/5 last:border-0 first:rounded-t-lg last:rounded-b-lg`}>
                        <span class="opacity-60">{item.label}</span>
                        <span class="font-bold">{item.val ?? '-'}{item.unit}</span>
                      </div>
                    ))}
                  </div>
               </div>
             )}
          </section>
        </div>
      </div>
    </div>
  </div>

    <!-- Triple Logo Branding Footer -->
    <section class="py-24 border-t border-black/5 bg-black/1">
       <div class="container mx-auto px-4">
          <div class="flex flex-col md:flex-row items-center justify-center gap-12 md:gap-24 opacity-40 grayscale hover:grayscale-0 transition-all duration-1000">
             <Image src={logo1} alt="Bura Logo" class="h-16 w-auto object-contain" />
             <div class="w-px h-16 bg-black/10 hidden md:block"></div>
             <Image src={logo2} alt="Mrgudić Logo" class="h-16 w-auto object-contain" />
             <div class="w-px h-16 bg-black/10 hidden md:block"></div>
             <Image src={logo3} alt="Dingač Logo" class="h-16 w-auto object-contain" />
          </div>
          <div class="mt-16 text-center">
             <a href={`/${lang}`} class="inline-flex items-center gap-3 group text-bura-muted hover:text-bura-ink transition-colors">
                <span class="text-lg group-hover:-translate-x-1 transition-transform">←</span>
                <span class="font-playfair italic underline underline-offset-8 decoration-black/10 group-hover:decoration-current">
                   {isHR ? 'Povratak na kolekciju' : 'Back to collection'}
                </span>
             </a>
          </div>
       </div>
    </section>

  </main>

</Layout>

<style>
  /* Custom Paper Texture */
  main::after {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -2;
    background-color: #f7f3e9;
    background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
  }
</style>