---
import Layout from '../../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { useTranslations } from '../../../i18n/utils';
import WineRadarChart from '../../../components/wine/WineRadarChart.astro';
import WineNutrition from '../../../components/wine/WineNutrition.astro';
import MultiWineSelector from '../../../components/wine/MultiWineSelector.astro';

// SSR Performance: Cache the response for 10 minutes, allow stale for 1 hour
Astro.response.headers.set('Cache-Control', 'public, s-maxage=600, stale-while-revalidate=3600');

// Import logos for the bottom
import placeholderBottle from '../../../assets/boca-vina-mrgudic-placeholder.webp';
import whiteWinePlaceholder from '../../../assets/mrgudic-bura-bijelovino-placeholder.webp';

const { lang, slug: fullSlug } = Astro.params;

// Safety check for parameters
if (!lang || !fullSlug) {
  return Astro.redirect('/404');
}

const [baseSlug, batchFromUrl] = fullSlug.split('/');
const CMS_URL = "https://cms.mokalo.hr";

// Check for selected ID in query params (for multi-wine dispatcher)
const url = new URL(Astro.request.url);
const selectedId = url.searchParams.get('id');

let allMatches = [];
try {
  // Fetch all wines that match this slug (exact full slug match)
  const response = await fetch(`${CMS_URL}/api/vina?where[slug][equals]=${fullSlug}&locale=${lang}&depth=1`);
  if (response.ok) {
    const result = await response.json();
    allMatches = result.docs || [];
  }

  if (!allMatches || allMatches.length === 0) {
    // Fallback: try base slug if fullSlug failed (to support older URLs or base paths)
    if (fullSlug !== baseSlug) {
      const fallbackRes = await fetch(`${CMS_URL}/api/vina?where[slug][equals]=${baseSlug}&locale=${lang}&depth=1`);
      if (fallbackRes.ok) {
        const fallbackData = await fallbackRes.json();
        if (fallbackData.docs && fallbackData.docs.length > 0) {
          allMatches.push(...fallbackData.docs);
        }
      }
    }
  }
} catch (error) {
  console.error(`[SSR ERROR] Error fetching wine data from CMS:`, error);
  // Optional: allMatches remains empty, which will trigger 404/redirect below
}

if (!allMatches || allMatches.length === 0) return Astro.redirect('/404');

// Decide which wine to show
let vino = null;
if (selectedId) {
  vino = allMatches.find((v: any) => v.id === selectedId);
} else if (allMatches.length === 1) {
  vino = allMatches[0];
}

// Map Payload data to the structure the template expects
const data = vino ? {
  name: vino.naziv,
  category_title: vino.category_title,
  year: vino.year,
  alcohol: vino.alcohol,
  sort: vino.sort,
  aromas: vino.aromas?.map((a: any) => a.aroma) || [],
  character: vino.character,
  technicals: vino.technicals,
  profile: vino.profile,
  serving: vino.serving,
  pairings: vino.pairings,
  visual_theme: vino.visual_theme,
  ingredients: vino.ingredients,
  allergens: vino.allergens,
  nutricija: vino.nutricija,
  analiza: vino.analiza,
  image: vino.slika?.url || null,
  batches: [vino.boris_lot || vino.lot],
  boris_lot: vino.boris_lot || null,
  datum_punjenja: vino.datum_punjenja || null,
  region: vino.region || null,
  recycling: vino.recycling || null,
  producer: vino.producer || 'OPG Mrgudić-Bura',
  hero_image: vino.hero_image?.url || null,
} : null;

const t = useTranslations(lang as any);
// Always use boris_lot from CMS if available, fallback to batchFromUrl
const batch = vino ? ((data as any).boris_lot || batchFromUrl || null) : null;
const isHR = lang === 'hr';

// Fiksni prijevod regije (ne ovisi o CMS-u)
const regionValue = isHR ? 'Srednja i Južna Dalmacija' : 'Central and South Dalmatia';

const themeMap = {
  'Marica-Red': '#800000',
  'Rukatac-Blue': '#004080',
  'Amare-Gold': '#b8860b'
};

// Theme and visual logic for the selected wine
let themeColor = '#800000';
let heroTitle = '';

if (data) {
  themeColor = themeMap[(data.visual_theme?.theme_type as keyof typeof themeMap) || 'Marica-Red'];
  heroTitle = data.name.toUpperCase();
}
---

<Layout 
  title={data ? data.name : (isHR ? `Odabir: ${baseSlug}` : `Select: ${baseSlug}`)} 
  lang={lang} 
  description={data ? `${data.name} - ${data.category_title}` : (isHR ? 'Odaberite željeno vino' : 'Select your wine')}
>
   
  <main class="relative min-h-screen flex flex-col font-inter bg-bura-dark-bg overflow-x-hidden" style={data ? `--theme-color: ${themeColor};` : ''}>
    
    {data ? (
      <>
        <section class="relative pt-12 pb-24 px-4 min-h-[70vh] flex flex-col items-center justify-center">
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden">
            <h1 class="text-[25vw] font-bold font-playfair leading-none opacity-[0.03] whitespace-nowrap" style={`color: ${themeColor};`}>
              {heroTitle}
            </h1>
          </div>
          <div class="relative z-10 grow w-full flex items-center justify-center py-12">
            <Image 
              src={data.image || (data.visual_theme?.theme_type === 'Marica-Red' ? placeholderBottle : whiteWinePlaceholder)} 
              alt={data.name} 
              class="h-[50vh] w-auto object-contain drop-shadow-[0_40px_80px_rgba(0,0,0,0.8)] transform transition-all duration-1000 hover:scale-105"
              loading="eager"
              width={600}
              height={1200}
              transition:name={`bottle-${Astro.params.slug?.split('/')[0]}`}
            />
          </div>
          <div class="relative z-20 text-center space-y-1">
            <h2 class="font-playfair text-6xl md:text-8xl font-bold tracking-tighter text-white" transition:name={`title-${Astro.params.slug?.split('/')[0]}`}>
              {heroTitle}
            </h2>
            <p class="font-playfair italic text-xl md:text-2xl text-white/60 uppercase tracking-widest">{data.sort}</p>
          </div>
          <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-20 animate-bounce">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-bura-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7-7-7" />
            </svg>
          </div>
        </section>

        <div class="relative z-30 bg-bura-dark-paper/80 backdrop-blur-xl border-t border-bura-gold-500/20 rounded-t-[3rem] -mt-12 shadow-[0_-20px_50px_rgba(0,0,0,0.3)]">
          <div class="container mx-auto px-4 py-16 max-w-5xl">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
              <div class="lg:col-span-4 space-y-6">
                <div class="bg-bura-dark-bg p-8 rounded-3xl border border-bura-gold-500/20 shadow-xl space-y-6">
                   <div class="flex justify-between items-center border-b border-white/10 pb-4">
                      <span class="text-[10px] text-white/50 uppercase tracking-widest font-bold">{t('wine.year') || (isHR ? 'Godište' : 'Year')}</span>
                      <span class="font-playfair text-2xl font-bold text-white">{data.year}</span>
                   </div>
                   <div class="flex justify-between items-center border-b border-white/10 pb-4">
                       <span class="text-[10px] text-white/50 uppercase tracking-widest font-bold">{isHR ? 'Regija' : 'Region'}</span>
                       <span class="font-playfair text-xl text-white">{regionValue}</span>
                    </div>
                   <div class="flex justify-between items-center pb-2">
                      <span class="text-[10px] text-white/50 uppercase tracking-widest font-bold">{t('wine.alcohol')}</span>
                      <span class="font-bold text-2xl text-bura-gold-400">{data.alcohol}<span class="text-sm ml-1 opacity-60">%vol</span></span>
                   </div>
                   {batch && (
                    <div class="bg-bura-dark-paper p-4 rounded-2xl mt-4 border border-bura-gold-500/30">
                      <span class="text-xs text-bura-gold-400 uppercase tracking-widest block mb-2 font-bold">{isHR ? 'LOT - Oznaka serije (Boris LOT)' : 'LOT - Series (Boris LOT)'}</span>
                      <span class="font-mono text-3xl tracking-tighter font-bold text-white">{batch}</span>
                      {data.datum_punjenja && (
                        <div class="mt-3 pt-3 border-t border-white/10 flex justify-between items-center">
                          <span class="text-[10px] text-white/40 uppercase tracking-widest font-bold">{isHR ? 'Punjenje' : 'Filling'}</span>
                          <span class="text-sm font-bold text-white/70">{new Date(data.datum_punjenja).toLocaleDateString(isHR ? 'hr-HR' : 'en-US')}</span>
                        </div>
                      )}
                    </div>
                   )}
                   <div class="grid grid-cols-2 gap-3 pt-4">
                      <button onclick="window.print()" class="flex flex-col items-center justify-center p-4 bg-bura-dark-paper border border-white/10 rounded-2xl hover:bg-bura-gold-500/10 hover:border-bura-gold-500/40 transition-all group">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mb-1 text-white/50 group-hover:text-bura-gold-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        <span class="text-[9px] font-bold uppercase tracking-widest text-white/50 group-hover:text-bura-gold-400">{isHR ? 'PDF List' : 'Wine Sheet'}</span>
                      </button>
                      <button id="share-btn" class="flex flex-col items-center justify-center p-4 bg-bura-dark-paper border border-white/10 rounded-2xl hover:bg-bura-gold-500/10 hover:border-bura-gold-500/40 transition-all group">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mb-1 text-white/50 group-hover:text-bura-gold-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                        </svg>
                        <span class="text-[9px] font-bold uppercase tracking-widest text-white/50 group-hover:text-bura-gold-400">{isHR ? 'Podijeli' : 'Share'}</span>
                      </button>
                   </div>
                </div>
              </div>

              <div class="lg:col-span-8 space-y-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  <section class="bg-bura-dark-bg/60 backdrop-blur-sm p-6 rounded-2xl border border-white/10 shadow-sm flex flex-col items-center">
                    <h2 class="font-playfair text-xl mb-6 uppercase tracking-widest text-center text-bura-gold-400">{isHR ? 'Karakter Vina' : 'Wine Character'}</h2>
                    <WineRadarChart profile={data.profile} themeColor={themeColor} isHR={isHR} />
                  </section>
                  <div class="space-y-8">
                    <section class="bg-bura-dark-bg/60 backdrop-blur-sm p-6 rounded-2xl border border-white/10 shadow-sm">
                      <h2 class="font-playfair text-xl mb-4 uppercase tracking-widest text-bura-gold-400">{isHR ? 'Arome' : 'Aromas'}</h2>
                      <div class="flex flex-wrap gap-2">
                        {data.aromas.map((aroma: string) => (
                          <span class="px-3 py-1 bg-bura-dark-paper rounded-full text-xs border border-white/10 text-bura-gold-400">{aroma}</span>
                        ))}
                      </div>
                      <div class="mt-6 pt-6 border-t border-white/10">
                        <h3 class="text-[10px] font-bold uppercase tracking-widest mb-2 text-white/40">{isHR ? 'Karakter' : 'Character'}</h3>
                        <p class="text-sm italic leading-relaxed text-white/70">"{data.character}"</p>
                      </div>
                    </section>
                    <section class="bg-bura-dark-bg/60 backdrop-blur-sm p-6 rounded-2xl border border-white/10 shadow-sm overflow-hidden relative">
                      <div class="absolute top-0 right-0 w-24 h-24 -mr-8 -mt-8 rounded-full opacity-10" style={`background-color: ${themeColor};`}></div>
                      <h2 class="font-playfair text-xl mb-4 uppercase tracking-widest text-bura-gold-400">{isHR ? 'Serviranje' : 'Serving'}</h2>
                      <div class="grid grid-cols-2 gap-4">
                        <div>
                          <span class="text-[9px] text-white/40 uppercase tracking-[0.2em] block mb-1">{isHR ? 'Temperatura' : 'Temperature'}</span>
                          <p class="font-bold text-lg text-white">{data.serving.temp}</p>
                        </div>
                        <div>
                          <span class="text-[9px] text-white/40 uppercase tracking-[0.2em] block mb-1">{isHR ? 'Preporučena čaša' : 'Glassware'}</span>
                          <p class="text-sm leading-tight text-white/70">{data.serving.glass}</p>
                        </div>
                      </div>
                    </section>
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                   <section class="bg-bura-dark-bg/60 backdrop-blur-sm p-6 rounded-2xl border border-white/10 shadow-sm">
                       <h2 class="font-playfair text-xl mb-4 uppercase tracking-widest text-bura-gold-400">{isHR ? 'Tehnikalije' : 'Technicals'}</h2>
                       <p class="text-sm leading-relaxed text-white/60">{data.technicals}</p>
                   </section>
<section class="bg-bura-dark-bg/60 backdrop-blur-md p-6 rounded-2xl border border-white/10 shadow-lg">
                       <h2 class="font-playfair text-xl mb-6 uppercase tracking-widest text-center text-bura-gold-400">{isHR ? 'Sljubljivanje' : 'Pairing'}</h2>
                       <div class="space-y-4">
                          {data.pairings.map((p: any) => (
                             <div class="flex items-center gap-4 p-4 bg-bura-dark-paper rounded-xl border border-white/10">
                                <div class="w-12 h-12 rounded-full flex items-center justify-center shrink-0 text-lg" style={`background-color: ${themeColor}20; color: ${themeColor};`}><span class="text-sm font-bold uppercase">{p.icon}</span></div>
                                <p class="text-base text-white/80 leading-snug font-medium">{p.desc}</p>
                             </div>
                          ))}
                       </div>
                    </section>
                </div>

                <WineNutrition lang={lang} data={data} themeColor={themeColor} />
              </div>
            </div>
          </div>
        </div>
      </>
    ) : (
      <MultiWineSelector allMatches={allMatches} lang={lang as string} baseSlug={baseSlug} themeMap={themeMap} />
    )}

    <section class="py-24 border-t border-white/10 bg-bura-dark-bg text-center">
       <div class="container mx-auto px-4">
          <div class="flex flex-col md:flex-row items-center justify-center gap-12 md:gap-24 mb-16">
             <span class="font-playfair text-2xl font-bold text-bura-gold-500">MRGUDIĆ</span>
             <span class="font-playfair text-2xl font-bold text-bura-gold-500">BURA</span>
          </div>
          {data && (
             <a href={`/${lang}`} class="inline-flex items-center gap-3 group text-white/50 hover:text-bura-gold-400 transition-colors">
                <span class="text-lg group-hover:-translate-x-1 transition-transform">←</span>
                <span class="font-playfair italic underline underline-offset-8 decoration-white/20 group-hover:decoration-bura-gold-400 group-hover:text-bura-gold-400">
                   {isHR ? 'Povratak na kolekciju' : 'Back to collection'}
                </span>
             </a>
          )}
       </div>
    </section>

  </main>

  {data && (
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const shareBtn = document.getElementById('share-btn');
        if (shareBtn) {
          shareBtn.addEventListener('click', async () => {
            try {
              await navigator.share({
                title: document.title,
                text: 'Provjerite digitalnu etiketu Mrgudić Bura Vina',
                url: window.location.href
              });
            } catch (err) {
              console.log('Share failed or cancelled');
            }
          });
        }
      });
    </script>
  )}

</Layout>