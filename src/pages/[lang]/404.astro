---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'hr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
---

<Layout title={lang === 'hr' ? 'Stranica ne postoji' : 'Page Not Found'} lang={lang}>
  <main class="container mx-auto px-4 py-40 grow text-center">
    <h1 class="font-playfair text-6xl text-gold mb-6">404</h1>
    <p class="text-text-muted text-xl mb-8">
      {lang === 'hr' ? 'Stranica ne postoji' : 'Page not found'}
    </p>
    <a href={`/${lang}`} class="inline-block px-6 py-3 border border-gold/30 hover:border-gold hover:bg-gold/10 transition text-gold">
      {lang === 'hr' ? 'Povratak na početnu' : 'Back to home'}
    </a>
  </main>
</Layout>
