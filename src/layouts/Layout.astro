---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="hr">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Mrgudić Bura Vina QR Landing System" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Mrgudić Bura Vina</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
	</head>
	<body class="bg-dark text-text-light font-inter selection:bg-gold/30 selection:text-gold min-h-screen flex flex-col antialiased">
		<slot />
	</body>
</html>
